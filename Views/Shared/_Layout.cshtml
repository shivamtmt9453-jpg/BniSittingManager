<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <title>BNI Evolve </title>
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content="" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="~/assets/images/favicon.png" />

    <!-- Icon Font CSS -->
    <link rel="stylesheet" href="~/assets/css/plugins/all.min.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/flaticon.css" />

    <!-- Plugins CSS -->
    <link rel="stylesheet" href="~/assets/css/plugins/bootstrap.min.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/aos.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/magnific-popup.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/lightbox.min.css" />
    <link rel="stylesheet" href="~/assets/css/plugins/gijgo.min.css" />

    <!-- Main Style CSS -->
    <link rel="stylesheet" href="~/assets/css/style1.css" />

    <style>
        .ddl {
            box-shadow: none;
            border: 0;
            padding: 10px 20px;
            max-width: 100%;
            width: 100%;
            font-size: 14px;
            line-height: 40px;
            transition: all 0.3s linear;
            height: 50px;
            color: grey;
        }

        input:focus {
            background: none;
        }
    </style>
     
</head>
<body>
    <div class="main-wrapper">

        <!-- Header Start  -->
        <div id="header" class="section exvent-header-section">
            <div class="container-fluid">
                <!-- Header Wrap Start  -->
                <div class="header-wrap">
                    <div class="header-logo" style="width:450px;">
                        <a href="/">
                            <img src="~/assets/img/bni-logo.png" alt="" style="width:80%; padding-left:30px; margin: 10px 0px 10px 0px;" />
                        </a>
                    </div>

                    <div class="header-menu d-none d-lg-block">
                         <ul class="main-menu">
                            <li>
                                <a class="font-weight-bold" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                               
                            <li>
                                <a class="font-weight-bold" asp-area="" asp-controller="Register" asp-action="BniMember">Member Register</a>
                            </li>

                            <li>
                                <a class="font-weight-bold" asp-area="" asp-controller="Register" asp-action="BniVisitor">Visitor Register</a>
                            </li>
                             
                        </ul> 
                    </div>

                    <!-- Header Meta Start -->
                    <div class="header-meta">
                        <div class="header-btn d-none d-xl-block">
                            <a class="btn" href="/Account/Login" target="_blank">Login</a>
                        </div>
                        <!-- Header Toggle Start -->
                        <div class="header-toggle d-lg-none">
                            <button type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasExample">
                                <span></span>
                                <span></span>
                                <span></span>
                            </button>
                        </div>
                        <!-- Header Toggle End -->
                    </div>
                    <!-- Header Meta End  -->

                </div>
                <!-- Header Wrap End  -->

            </div>
        </div>
        <!-- Header End -->
        <!-- Offcanvas Start-->
        <div class="offcanvas offcanvas-start" id="offcanvasExample">
            <div class="offcanvas-header">
                <!-- Offcanvas Logo Start -->
                <div class="offcanvas-logo">
                    <a href="/"><img src="~/assets/img/orginal-logo.jpeg" alt="" /></a>
                </div>
                <!-- Offcanvas Logo End -->
                <button type="button" class="close-btn" data-bs-dismiss="offcanvas"><i class="flaticon-close"></i></button>
            </div>

            <!-- Offcanvas Body Start -->
            <div class="offcanvas-body">
                <div class="offcanvas-menu">
                    <ul class="main-menu">
                  
                    </ul>
                </div>
            </div>
            <!-- Offcanvas Body End -->
        </div>
        <!-- Offcanvas End -->
        @RenderBody()

        <!-- Footer Section Start -->
        <div class="footer-section-02 section-padding-02 purple-bg-2">
            <img src="~/assets/images/shape/footer-2-shape1.png" alt="shape" class="footer-shape-1" />
            <img src="~/assets/images/shape/footer-2-shape2.png" alt="shape" class="footer-shape-2" />
            <img src="~/assets/images/shape/footer-2-shape3.png" alt="shape" class="footer-shape-3" />
            <div class="container">
                <div class="row justify-content-sm-start justify-content-center">
                    <div class="col-lg-4 col-sm-6 col-10">
                        <div class="footer-widget">
                            <div class="footer-widget-address">
                                <h3 class="widget-title">Venue Location</h3>
                                <div class="widget-content"> 
                                    <a href="#" class="vanue-location">Lawn 2, Indira Gandhi Pratishthan<br /> Lucknow, Uttar Pradesh</a>
                                    <div style="font-size: 15px; font-weight: bold; color: #fff;">
                                        <a href="/Account/Login" target="_blank">Admin Login</a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6 col-10">
                        <div class="footer-widget text-md-center">
                            <img src="~/assets/img/bni-logo.png" alt="logo" class="footer-logo">
                            <!-- Footer Copyright Text Start -->
                            <div class="copyright-text text-md-center text-start">
                                <p>
                                    2026 BNI Evolve. Powered by Triangle Mind Technology Pvt. Ltd. All Rights Reserved.

                                    <a href="http://trianglemind.in/" target="_blank"><img src="~/assets/img/tmt.PNG" alt="trianglemind" /> </a>
                                </p>
                            </div>

                            <!-- Footer Copyright Text End -->
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-6 col-10">
                        <div class="footer-widget d-lg-flex justify-content-lg-end">
                            <div class="widget-wrapper text-lg-start">
                                <div class="footer-social-2">
                                    <div class="social-title-2">
                                        <h4>Contact With us</h4>
                                    </div>
                                    <div class="widget-content mt-3">
                                        <ul>
                                            <li><span style="font-size:22px; color:#ffae4a;"><i class="flaticon-phone-call"></i> </span> &nbsp; &nbsp; <a href="tel:+919415026828" class="event-meta" style="color:white; font-size:16px; margin-top:5px"> +91 9415026828</a></li>
                                            <li><span style="font-size:22px; color:#ffae4a;"><i class="flaticon-phone-call"></i> </span> &nbsp; &nbsp; <a href="tel:+919214604659" class="event-meta" style="color:white; font-size:16px; margin-top:5px"> +91 9214604659</a></li>
                                            <li><span style="font-size:22px; color:#ffae4a;"><i class="far fa-envelope"></i> </span> &nbsp; &nbsp; &nbsp; <a href="mailto:Support@meetingsdirect.net" class="event-meta" style="color:white; font-size:16px; margin-top:5px" ">Support@meetingsdirect.net</a></li>

                                        </ul>
                                    </div>
                                    <ul class="social-list text-sm-start text-center">
                                        <li><a href="https://www.facebook.com/bnilucknownorth/" target="_blank"><i class="fab fa-facebook-f"></i></a></li>

                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Footer Section End -->
        <!-- back to top start -->
        <div class="progress-wrap">
            <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
                <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98" />
            </svg>
        </div>
        <!-- back to top end -->

    </div>

    <!-- JS
    ============================================ -->
    <script src="~/assets/js/vendor/jquery-1.12.4.min.js"></script>
    <script src="~/assets/js/vendor/modernizr-3.11.2.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="~/assets/js/plugins/popper.min.js"></script>
    <script src="~/assets/js/plugins/bootstrap.min.js"></script>

    <!-- Plugins JS -->
    <script src="~/assets/js/plugins/swiper-bundle.min.js"></script>
    <script src="~/assets/js/plugins/aos.js"></script>
    <script src="~/assets/js/plugins/waypoints.min.js"></script>
    <script src="~/assets/js/plugins/back-to-top.js"></script>
    <script src="~/assets/js/plugins/jquery.counterup.min.js"></script>
    <script src="~/assets/js/plugins/appear.min.js"></script>
    <script src="~/assets/js/plugins/jquery.magnific-popup.min.js"></script>
    <script src="~/assets/js/plugins/lightbox.min.js"></script>
    <script src="~/assets/js/plugins/gijgo.min.js"></script>


    <!--====== Use the minified version files listed below for better performance and remove the files listed above ======-->
    <!-- Main JS -->
    <script src="~/assets/js/main.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @if (TempData["Message"] != null)
    {
        <script>
            Swal.fire({
                icon: '@TempData["MessageType"]',
                title: '@TempData["Message"]',
                showConfirmButton: true,
                confirmButtonText: 'OK'
            });
        </script>
    }
            
       
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
