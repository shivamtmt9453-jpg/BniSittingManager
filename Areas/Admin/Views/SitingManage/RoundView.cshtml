@model List<BniSittingManager.Areas.Admin.Models.RoundViewVM>


@{
    ViewData["Title"] = "Round View";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h2>Round Wise Seating View</h2>
  
<hr />

<!-- ================= ROUND INFO ================= -->
<div class="mb-3">
    <span class="badge bg-dark">
        Showing Seating for Selected Round
    </span>
</div>

<!-- ================= TABLE ================= -->
<table class="table table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th>Table Name</th>
            <th>Seat No</th>
            <th>User Name</th>
            <th>Type</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Count > 0)
        {
          
@foreach (var item in Model)
{
    <tr>
        <td>@item.TableName</td>
        <td>@item.SeatNumber</td>
        <td>@item.UserName</td>
        <td>@item.Type</td>
    </tr>
}
        }
        else
        {
            <tr>
                <td colspan="4" class="text-center text-danger">
                    No Seating Data Found for this Round
                </td>
            </tr>
        }
    </tbody>
</table>