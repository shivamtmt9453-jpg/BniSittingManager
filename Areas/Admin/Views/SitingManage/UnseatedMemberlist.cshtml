@model List<BniSittingManager.Areas.Admin.Models.UnseatedMemberVM>

@{
    ViewData["Title"] = "Unseated Member Report";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<section class="content-header">
    <h1>Unseated Member Report</h1>
    <ol class="breadcrumb">
        <li><a href="/Admin/Dashboard"><i class="fa fa-home"></i> Home</a></li>
        <li class="active">Unseated Member Report</li>
    </ol>
</section>
<section class="content">
    <div class="box">
        <div class="box-header with-border">
         
            <div class="pull-left">
                <a class="btn btn-danger"
                   href="/Admin/SitingManage/ExportExcelUnseatedMember">
                    📥 Export All Unseated
                </a>
                <select id="pageSizeSelect" class="form-control input-sm" style="width:100px; display:inline-block;">
                    <option value="20">20</option>
                    <option value="30">30</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>

            </div>
        </div>
        <div class="box-body table-responsive">
            <table class="table table-bordered table-striped paginated-table">
                <thead class="thead-dark">
                    <tr>
                        <th>Sr. No.</th>
                        <th>Round</th>
                        <th>User Name</th>
                        <th>User Id</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Type</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int srNo = 1;

                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@srNo</td>
                                <td>@item.RoundName</td>
                                <td>@item.UserName</td>
                                <td>@item.MemberId</td>
                                <td>@item.Email</td>
                                <td>@item.Phone</td>
                                <td>
                                    <span class="badge bg-danger">Unseated</span>
                                </td>
                            </tr>

                            srNo++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-danger">
                                No Unseated Members Found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>